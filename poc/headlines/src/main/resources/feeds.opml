<?xml version="1.0" encoding="UTF-8"?>
<!--
  Default feeds for the headlines PoC, organised to mirror RSSOwl's bundled `default_feeds.xml`
  (the "Import Recommended Feeds" first-start option): the same kind of category folders, in the
  same alphabetical order (Business first). RSSOwl's 2009 URLs are mostly dead, so these are current
  (2026) section feeds from reliable publishers (BBC, The Guardian, NYT, NPR, etc.). Our own list of
  facts, not a copy of the EPL original.

  Folder = category (left tree + "Group by: Category"); each <outline xmlUrl=...> is one feed.
-->
<opml version="1.1">
    <head>
        <title>Headlines PoC — default feeds (after RSSOwl)</title>
    </head>
    <body>
        <outline text="Business" title="Business">
            <outline type="rss" text="BBC Business" xmlUrl="https://feeds.bbci.co.uk/news/business/rss.xml"/>
            <outline type="rss" text="Guardian Business" xmlUrl="https://www.theguardian.com/uk/business/rss"/>
            <outline type="rss" text="NYT Business" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Business.xml"/>
        </outline>
        <outline text="Entertainment" title="Entertainment">
            <outline type="rss" text="BBC Entertainment &amp; Arts" xmlUrl="https://feeds.bbci.co.uk/news/entertainment_and_arts/rss.xml"/>
            <outline type="rss" text="Guardian Culture" xmlUrl="https://www.theguardian.com/culture/rss"/>
            <outline type="rss" text="NYT Arts" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Arts.xml"/>
        </outline>
        <outline text="Health" title="Health">
            <outline type="rss" text="BBC Health" xmlUrl="https://feeds.bbci.co.uk/news/health/rss.xml"/>
            <outline type="rss" text="NYT Health" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Health.xml"/>
            <outline type="rss" text="NPR Health" xmlUrl="https://feeds.npr.org/1128/rss.xml"/>
        </outline>
        <outline text="Politics" title="Politics">
            <outline type="rss" text="BBC Politics" xmlUrl="https://feeds.bbci.co.uk/news/politics/rss.xml"/>
            <outline type="rss" text="Guardian Politics" xmlUrl="https://www.theguardian.com/politics/rss"/>
            <outline type="rss" text="NPR Politics" xmlUrl="https://feeds.npr.org/1014/rss.xml"/>
        </outline>
        <outline text="Science" title="Science">
            <outline type="rss" text="BBC Science &amp; Environment" xmlUrl="https://feeds.bbci.co.uk/news/science_and_environment/rss.xml"/>
            <outline type="rss" text="NYT Science" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Science.xml"/>
            <outline type="rss" text="Guardian Science" xmlUrl="https://www.theguardian.com/science/rss"/>
        </outline>
        <outline text="Sports" title="Sports">
            <outline type="rss" text="BBC Sport" xmlUrl="https://feeds.bbci.co.uk/sport/rss.xml"/>
            <outline type="rss" text="Guardian Sport" xmlUrl="https://www.theguardian.com/uk/sport/rss"/>
            <outline type="rss" text="ESPN" xmlUrl="https://www.espn.com/espn/rss/news"/>
        </outline>
        <outline text="Technology" title="Technology">
            <outline type="rss" text="TechCrunch" xmlUrl="https://techcrunch.com/feed/"/>
            <outline type="rss" text="The Verge" xmlUrl="https://www.theverge.com/rss/index.xml"/>
            <outline type="rss" text="Wired" xmlUrl="https://www.wired.com/feed/rss"/>
            <outline type="rss" text="Ars Technica" xmlUrl="https://feeds.arstechnica.com/arstechnica/index"/>
        </outline>
        <outline text="World" title="World">
            <outline type="rss" text="BBC World" xmlUrl="https://feeds.bbci.co.uk/news/world/rss.xml"/>
            <outline type="rss" text="NYT World" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/World.xml"/>
            <outline type="rss" text="Guardian World" xmlUrl="https://www.theguardian.com/world/rss"/>
            <outline type="rss" text="NPR World" xmlUrl="https://feeds.npr.org/1004/rss.xml"/>
        </outline>
    </body>
</opml>
