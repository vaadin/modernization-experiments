<?xml version="1.0" encoding="UTF-8"?>
<!--
  Default feeds for the headlines PoC, following RSSOwl's bundled `default_feeds.xml` STRUCTURE
  (the "Import Recommended Feeds" first-start option): the same category folders (Business …
  Weblogs) AND the same top-level *ungrouped* channels (RSSOwlnix News, BBC News, CNN, Gizmodo,
  Engadget, Google News, MarketWatch …) sitting beside the folders. RSSOwl's 2009 URLs are mostly
  dead, so these are current (2026) feeds from reliable publishers. Our own list of facts, not a
  copy of the EPL original.

  Folder = category (left tree + "Group by: Category"); feeds directly under <body> are ungrouped
  channels (rendered as top-level rows, like RSSOwl). Each <outline xmlUrl=...> is one feed.
-->
<opml version="1.1">
    <head>
        <title>Headlines PoC — default feeds (after RSSOwl)</title>
    </head>
    <body>
        <!-- ===== category folders (alphabetical, like RSSOwl) ===== -->
        <outline text="Business" title="Business">
            <outline type="rss" text="BBC Business" xmlUrl="https://feeds.bbci.co.uk/news/business/rss.xml"/>
            <outline type="rss" text="Guardian Business" xmlUrl="https://www.theguardian.com/uk/business/rss"/>
            <outline type="rss" text="NYT Business" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Business.xml"/>
        </outline>
        <outline text="Computers" title="Computers">
            <outline type="rss" text="Ars Technica" xmlUrl="https://feeds.arstechnica.com/arstechnica/index"/>
            <outline type="rss" text="The Register" xmlUrl="https://www.theregister.com/headlines.atom"/>
            <outline type="rss" text="Slashdot" xmlUrl="https://rss.slashdot.org/Slashdot/slashdotMain"/>
        </outline>
        <outline text="Entertainment" title="Entertainment">
            <outline type="rss" text="BBC Entertainment &amp; Arts" xmlUrl="https://feeds.bbci.co.uk/news/entertainment_and_arts/rss.xml"/>
            <outline type="rss" text="Guardian Culture" xmlUrl="https://www.theguardian.com/culture/rss"/>
            <outline type="rss" text="NYT Arts" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Arts.xml"/>
        </outline>
        <outline text="Health" title="Health">
            <outline type="rss" text="BBC Health" xmlUrl="https://feeds.bbci.co.uk/news/health/rss.xml"/>
            <outline type="rss" text="NYT Health" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Health.xml"/>
            <outline type="rss" text="NPR Health" xmlUrl="https://feeds.npr.org/1128/rss.xml"/>
        </outline>
        <outline text="News" title="News">
            <outline type="rss" text="BBC News" xmlUrl="https://feeds.bbci.co.uk/news/rss.xml"/>
            <outline type="rss" text="NYT — Home" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml"/>
            <outline type="rss" text="Guardian World" xmlUrl="https://www.theguardian.com/world/rss"/>
            <outline type="rss" text="NPR News" xmlUrl="https://feeds.npr.org/1001/rss.xml"/>
        </outline>
        <outline text="Politics" title="Politics">
            <outline type="rss" text="BBC Politics" xmlUrl="https://feeds.bbci.co.uk/news/politics/rss.xml"/>
            <outline type="rss" text="Guardian Politics" xmlUrl="https://www.theguardian.com/politics/rss"/>
            <outline type="rss" text="NPR Politics" xmlUrl="https://feeds.npr.org/1014/rss.xml"/>
        </outline>
        <outline text="Science" title="Science">
            <outline type="rss" text="BBC Science &amp; Environment" xmlUrl="https://feeds.bbci.co.uk/news/science_and_environment/rss.xml"/>
            <outline type="rss" text="NYT Science" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/Science.xml"/>
            <outline type="rss" text="Guardian Science" xmlUrl="https://www.theguardian.com/science/rss"/>
        </outline>
        <outline text="Sports" title="Sports">
            <outline type="rss" text="BBC Sport" xmlUrl="https://feeds.bbci.co.uk/sport/rss.xml"/>
            <outline type="rss" text="Guardian Sport" xmlUrl="https://www.theguardian.com/uk/sport/rss"/>
            <outline type="rss" text="ESPN" xmlUrl="https://www.espn.com/espn/rss/news"/>
        </outline>
        <outline text="Technology" title="Technology">
            <outline type="rss" text="TechCrunch" xmlUrl="https://techcrunch.com/feed/"/>
            <outline type="rss" text="The Verge" xmlUrl="https://www.theverge.com/rss/index.xml"/>
            <outline type="rss" text="Wired" xmlUrl="https://www.wired.com/feed/rss"/>
        </outline>
        <outline text="Weblogs" title="Weblogs">
            <outline type="rss" text="Daring Fireball" xmlUrl="https://daringfireball.net/feeds/main"/>
            <outline type="rss" text="kottke.org" xmlUrl="https://feeds.kottke.org/main"/>
            <outline type="rss" text="Boing Boing" xmlUrl="https://boingboing.net/feed"/>
            <outline type="rss" text="Hacker News" xmlUrl="https://news.ycombinator.com/rss"/>
        </outline>

        <outline text="Food" title="Food">
            <outline type="rss" text="NYT Dining" xmlUrl="https://rss.nytimes.com/services/xml/rss/nyt/DiningandWine.xml"/>
            <outline type="rss" text="Guardian Food" xmlUrl="https://www.theguardian.com/food/rss"/>
            <outline type="rss" text="Smitten Kitchen" xmlUrl="https://smittenkitchen.com/feed/"/>
        </outline>
        <outline text="Internet" title="Internet">
            <outline type="rss" text="Mashable" xmlUrl="https://mashable.com/feeds/rss/all"/>
            <outline type="rss" text="The Next Web" xmlUrl="https://thenextweb.com/feed"/>
            <outline type="rss" text="TorrentFreak" xmlUrl="https://torrentfreak.com/feed/"/>
        </outline>
        <outline text="Music" title="Music">
            <outline type="rss" text="Pitchfork" xmlUrl="https://pitchfork.com/feed/feed-news/rss"/>
            <outline type="rss" text="NPR Music" xmlUrl="https://feeds.npr.org/1039/rss.xml"/>
            <outline type="rss" text="Stereogum" xmlUrl="https://www.stereogum.com/feed/"/>
        </outline>
        <outline text="Podcast" title="Podcast">
            <outline type="rss" text="NPR Up First" xmlUrl="https://feeds.npr.org/510318/podcast.xml"/>
            <outline type="rss" text="This American Life" xmlUrl="https://www.thisamericanlife.org/podcast/rss.xml"/>
        </outline>
        <outline text="Software" title="Software">
            <outline type="rss" text="The GitHub Blog" xmlUrl="https://github.blog/feed/"/>
            <outline type="rss" text="InfoQ" xmlUrl="https://feed.infoq.com/"/>
        </outline>

        <!-- ===== ungrouped channels (top-level, like RSSOwl's root entries) ===== -->
        <outline type="rss" text="RSSOwlnix News" xmlUrl="https://xyrio.github.io/RSSOwlnix-site/updates.rss"/>
        <outline type="rss" text="CNN" xmlUrl="https://rss.cnn.com/rss/edition.rss"/>
        <outline type="rss" text="Gizmodo" xmlUrl="https://gizmodo.com/rss"/>
        <outline type="rss" text="Engadget" xmlUrl="https://www.engadget.com/rss.xml"/>
        <outline type="rss" text="Google News" xmlUrl="https://news.google.com/rss"/>
        <outline type="rss" text="MarketWatch" xmlUrl="https://feeds.content.dowjones.io/public/rss/mw_topstories"/>
    </body>
</opml>
